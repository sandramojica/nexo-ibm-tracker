# ─────────────────────────────────────────────
#  IBM Objectives Tracker – Environment Config
#  Copy to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── App ────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Bind only to localhost (security: never 0.0.0.0)
HOST=127.0.0.1

# ── IBM SSO / OAuth 2.0 ────────────────────────
# Obtain client credentials from IBM App ID or w3id
IBM_CLIENT_ID=your_ibm_client_id
IBM_CLIENT_SECRET=your_ibm_client_secret
IBM_TOKEN_URL=https://login.ibm.com/oidc/endpoint/default/token
IBM_USERINFO_URL=https://login.ibm.com/oidc/endpoint/default/userinfo

# ── SuccessFactors API ─────────────────────────
# Base URL for your IBM SuccessFactors tenant
SF_BASE_URL=https://apisalesdemo2.successfactors.eu/odata/v2
SF_API_KEY=your_sf_api_key
# Company ID visible in your SF URL: /sf/start#/companyID=<THIS>
SF_COMPANY_ID=your_company_id

# ── Your Learning (IBM Cornerstone / LMS) ─────
# Internal LMS REST API endpoint provided by IBM IT
YOUR_LEARNING_BASE_URL=https://yourlearning.ibm.com/api/v1
YOUR_LEARNING_API_KEY=your_yourlearning_api_key

# ── Time (IBM Time Recording) ─────────────────
# Internal Time API – request access from IBM IT Help Desk
TIME_API_BASE_URL=https://w3.ibm.com/time/api/v1
TIME_API_KEY=your_time_api_key

# ── Email Notifications (SMTP) ────────────────
# Use IBM internal SMTP relay or an approved SMTP service
SMTP_HOST=smtp.ibm.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@ibm.com
SMTP_PASS=your_smtp_password
NOTIFICATION_FROM=no-reply-objectives@ibm.com

# ── Web Push Notifications (VAPID) ────────────
# Generate once with: npm run setup:vapid
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your_email@ibm.com

# ── Session / JWT ─────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=change_this_to_a_random_64_byte_hex_string
JWT_EXPIRES_IN=8h

# ── Cache (seconds) ───────────────────────────
CACHE_TTL_SECONDS=300

# ── Demo mode (no IBM network / VPN required) ─
# Set to true to use simulated data and bypass all IBM API calls.
# Switch to false when running on IBM network with real credentials.
DEMO=true

# ── Employee Profile Fallback ──────────────────
# Used when SuccessFactors is unreachable (e.g. no VPN).
# These values drive course recommendations and hour alerts.
USER_ID=03045693
USER_NAME=Sandra Milena Mojica Duarte
USER_EMAIL=your_email@ibm.com
USER_BAND=4
USER_ROLE=Analista Contable
USER_PROFESSION=Contadora Publica
USER_PRACTICE=Consulting
USER_SPECIALIZATION=R2R/P2P/O2C

# ── Learning Preferences ───────────────────────
# Native language and preferred language for course suggestions.
# COURSE_LANG: es=Spanish first, en=English first, both=no preference
USER_NATIVE_LANG=es
USER_LEARNING_LANG=en
# Comma-separated interest areas for extra course recommendations
# Options: soft-skills, english, programming, communication, automation, badges
USER_INTERESTS=english,soft-skills,communication,programming,automation,badges
